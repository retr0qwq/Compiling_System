Grammar

    0 $accept: PROGRAM $end

    1 PROGRAM: STMT_LIST
    2        | PROGRAM END

    3 STMT_LIST: STMT
    4          | STMT_LIST STMT

    5 STMT: EXPR_STMT
    6     | VAR_DECL_STMT
    7     | FUNC_DECL_STMT
    8     | FOR_STMT
    9     | IF_STMT
   10     | CONTINUE_STMT
   11     | SEMICOLON
   12     | SLASH_COMMENT
   13     | BLOCK_STMT
   14     | RETURN_STMT
   15     | WHILE_STMT
   16     | BREAK_STMT

   17 CONTINUE_STMT: CONTINUE SEMICOLON

   18 EXPR_STMT: EXPR SEMICOLON

   19 VAR_DECLARATION: TYPE VAR_DECLARATOR_LIST
   20                | CONST TYPE VAR_DECLARATOR_LIST

   21 VAR_DECL_STMT: VAR_DECLARATION SEMICOLON

   22 FUNC_BODY: LBRACE RBRACE
   23          | LBRACE STMT_LIST RBRACE

   24 FUNC_DECL_STMT: TYPE IDENT LPAREN PARAM_DECLARATOR_LIST RPAREN FUNC_BODY

   25 FOR_STMT: FOR LPAREN VAR_DECLARATION SEMICOLON EXPR SEMICOLON EXPR RPAREN STMT
   26         | FOR LPAREN EXPR SEMICOLON EXPR SEMICOLON EXPR RPAREN STMT

   27 IF_STMT: IF LPAREN EXPR RPAREN STMT
   28        | IF LPAREN EXPR RPAREN STMT ELSE STMT

   29 BLOCK_STMT: LBRACE RBRACE
   30           | LBRACE STMT_LIST RBRACE

   31 RETURN_STMT: RETURN SEMICOLON
   32            | RETURN EXPR SEMICOLON

   33 BREAK_STMT: BREAK SEMICOLON

   34 WHILE_STMT: WHILE LPAREN EXPR RPAREN STMT

   35 PARAM_DECLARATOR: TYPE IDENT
   36                 | TYPE IDENT LBRACKET RBRACKET
   37                 | TYPE IDENT LBRACKET RBRACKET ARRAY_DIMENSION_EXPR_LIST
   38                 | TYPE IDENT ARRAY_DIMENSION_EXPR_LIST

   39 PARAM_DECLARATOR_LIST: ε
   40                      | PARAM_DECLARATOR
   41                      | PARAM_DECLARATOR_LIST COMMA PARAM_DECLARATOR

   42 VAR_DECLARATOR: IDENT
   43               | IDENT ASSIGN INITIALIZER
   44               | IDENT LBRACKET RBRACKET
   45               | IDENT LBRACKET RBRACKET ARRAY_DIMENSION_EXPR_LIST
   46               | IDENT LBRACKET RBRACKET ASSIGN INITIALIZER
   47               | IDENT LBRACKET RBRACKET ARRAY_DIMENSION_EXPR_LIST ASSIGN INITIALIZER
   48               | IDENT ARRAY_DIMENSION_EXPR_LIST
   49               | IDENT ARRAY_DIMENSION_EXPR_LIST ASSIGN INITIALIZER

   50 VAR_DECLARATOR_LIST: VAR_DECLARATOR
   51                    | VAR_DECLARATOR_LIST COMMA VAR_DECLARATOR

   52 INITIALIZER: NOCOMMA_EXPR
   53            | LBRACE INITIALIZER_LIST RBRACE

   54 INITIALIZER_LIST: INITIALIZER
   55                 | INITIALIZER_LIST COMMA INITIALIZER

   56 ASSIGN_EXPR: LEFT_VAL_EXPR ASSIGN NOCOMMA_EXPR

   57 EXPR_LIST: NOCOMMA_EXPR
   58          | EXPR_LIST COMMA NOCOMMA_EXPR

   59 EXPR: NOCOMMA_EXPR
   60     | EXPR COMMA NOCOMMA_EXPR

   61 NOCOMMA_EXPR: LOGICAL_OR_EXPR
   62             | ASSIGN_EXPR

   63 LOGICAL_OR_EXPR: LOGICAL_AND_EXPR
   64                | LOGICAL_OR_EXPR OR LOGICAL_AND_EXPR

   65 LOGICAL_AND_EXPR: EQUALITY_EXPR
   66                 | LOGICAL_AND_EXPR AND EQUALITY_EXPR

   67 EQUALITY_EXPR: RELATIONAL_EXPR
   68              | EQUALITY_EXPR EQ RELATIONAL_EXPR
   69              | EQUALITY_EXPR NEQ RELATIONAL_EXPR

   70 RELATIONAL_EXPR: ADDSUB_EXPR
   71                | RELATIONAL_EXPR LT ADDSUB_EXPR
   72                | RELATIONAL_EXPR GT ADDSUB_EXPR
   73                | RELATIONAL_EXPR LE ADDSUB_EXPR
   74                | RELATIONAL_EXPR GE ADDSUB_EXPR

   75 ADDSUB_EXPR: MULDIV_EXPR
   76            | ADDSUB_EXPR PLUS MULDIV_EXPR
   77            | ADDSUB_EXPR MINUS MULDIV_EXPR

   78 MULDIV_EXPR: UNARY_EXPR
   79            | MULDIV_EXPR MUL UNARY_EXPR
   80            | MULDIV_EXPR DIV UNARY_EXPR
   81            | MULDIV_EXPR MOD UNARY_EXPR

   82 UNARY_EXPR: BASIC_EXPR
   83           | UNARY_OP UNARY_EXPR

   84 BASIC_EXPR: LITERAL_EXPR
   85           | LEFT_VAL_EXPR
   86           | LPAREN EXPR RPAREN
   87           | FUNC_CALL_EXPR

   88 FUNC_CALL_EXPR: IDENT LPAREN RPAREN
   89               | IDENT LPAREN EXPR_LIST RPAREN

   90 ARRAY_DIMENSION_EXPR: LBRACKET NOCOMMA_EXPR RBRACKET

   91 ARRAY_DIMENSION_EXPR_LIST: ARRAY_DIMENSION_EXPR
   92                          | ARRAY_DIMENSION_EXPR_LIST ARRAY_DIMENSION_EXPR

   93 LEFT_VAL_EXPR: IDENT
   94              | IDENT ARRAY_DIMENSION_EXPR_LIST

   95 LITERAL_EXPR: INT_CONST
   96             | FLOAT_CONST
   97             | LL_CONST

   98 TYPE: INT
   99     | FLOAT
  100     | VOID

  101 UNARY_OP: PLUS
  102         | MINUS
  103         | NOT


